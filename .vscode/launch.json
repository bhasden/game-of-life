{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "GameOfLife.Api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/src/GameOfLife.Api/bin/Debug/net10.0/GameOfLife.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/GameOfLife.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5088"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/scalar/v1"
      }
    },
  ]
}
